{
    "compilerOptions": {
      "module": "commonjs",
      "esModuleInterop": true,
      "target": "es6",
      "noImplicitAny": true,
      "moduleResolution": "node",
      "sourceMap": true,
      "outDir": "dist",
      "baseUrl": ".",
      "rootDir": "src",
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "useDefineForClassFields": true,
      "paths": {
        "*": [
          "node_modules/*"
        ],
      },
      "lib": [
        "es2015", "es5", "es6", "dom"
      ],
      "resolveJsonModule": true,
    },
    "include": [
      "src/**/*"
    ],
    "typeRoots": ["./node_modules/@types", "./src/types"]
  }